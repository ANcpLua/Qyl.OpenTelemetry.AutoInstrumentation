<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Qyl.AutoInstrumentation.SqlClient</RootNamespace>
    <AssemblyName>Qyl.AutoInstrumentation.SqlClient</AssemblyName>
    <PackageId>Qyl.AutoInstrumentation.SqlClient</PackageId>
    <Description>Zero-code AOT-native Microsoft.Data.SqlClient DiagnosticSource instrumentation for qyl.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.SqlClient" Version="7.0.1" />
  </ItemGroup>

  <ItemGroup>
    <None Include="buildTransitive\Qyl.AutoInstrumentation.SqlClient.targets"
          Pack="true"
          PackagePath="buildTransitive\" />
    <None Include="buildTransitive\Qyl.AutoInstrumentation.SqlClient.Bootstrap.g.cs"
          Pack="true"
          PackagePath="buildTransitive\" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Qyl.AutoInstrumentation\Qyl.AutoInstrumentation.csproj" />
    <ProjectReference Include="..\Qyl.AutoInstrumentation.DiagnosticListeners\Qyl.AutoInstrumentation.DiagnosticListeners.csproj" />
  </ItemGroup>

</Project>
