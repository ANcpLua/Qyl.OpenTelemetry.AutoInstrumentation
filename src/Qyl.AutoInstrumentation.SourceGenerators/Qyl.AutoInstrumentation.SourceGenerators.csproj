<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Roslyn analyzers/source generators must load in the host compiler, which targets
         netstandard2.0. This is the ONLY project that escapes the net10.0 / AOT baseline. -->
    <TargetFramework>netstandard2.0</TargetFramework>
    <RootNamespace>Qyl.AutoInstrumentation.SourceGenerators</RootNamespace>
    <AssemblyName>Qyl.AutoInstrumentation.SourceGenerators</AssemblyName>

    <IsRoslynComponent>true</IsRoslynComponent>
    <IsPackable>false</IsPackable>
    <IsPublishable>false</IsPublishable>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>

    <!-- Inherited AOT/trim flags are meaningless on netstandard2.0 — turn them off so the build
         stays warning-free under TreatWarningsAsErrors. -->
    <IsAotCompatible>false</IsAotCompatible>
    <IsTrimmable>false</IsTrimmable>
    <EnableTrimAnalyzer>false</EnableTrimAnalyzer>
    <EnableAotAnalyzer>false</EnableAotAnalyzer>
    <EnableSingleFileAnalyzer>false</EnableSingleFileAnalyzer>
    <PublishAot>false</PublishAot>
    <DefaultItemExcludes>$(DefaultItemExcludes);$(MSBuildProjectDirectory)/bin/**;$(MSBuildProjectDirectory)/obj/**</DefaultItemExcludes>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="$(MicrosoftCodeAnalysisCSharpVersion)" PrivateAssets="all" />
  </ItemGroup>

</Project>
