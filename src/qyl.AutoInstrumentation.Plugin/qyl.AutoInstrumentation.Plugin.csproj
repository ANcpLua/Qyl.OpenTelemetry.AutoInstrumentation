<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>Qyl.AutoInstrumentation.Plugin</RootNamespace>
    <AssemblyName>Qyl.AutoInstrumentation.Plugin</AssemblyName>
    <!-- M3: ensure referenced package DLLs land in bin so they can be deployed to the substrate store. -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <!-- Compile-time only: at runtime the reused substrate's OTel assemblies are used. -->
    <PackageReference Include="OpenTelemetry" Version="1.9.0" />
    <!-- M3: the qyl semconv registry drives the conformance check (no hardcoded keys). -->
    <PackageReference Include="Qyl.OpenTelemetry.SemanticConventions" Version="3.0.0" />
    <PackageReference Include="Qyl.OpenTelemetry.SemanticConventions.Incubating" Version="3.0.0" />
  </ItemGroup>

</Project>
