<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Qyl.OpenTelemetry.AutoInstrumentation</RootNamespace>
    <AssemblyName>Qyl.OpenTelemetry.AutoInstrumentation</AssemblyName>
    <PackageId>Qyl.OpenTelemetry.AutoInstrumentation</PackageId>
    <Description>AOT-native zero-code .NET instrumentation core. Source-generated semconv registry + Activity/Meter primitives. NO IL rewriting, NO CLR profiler attach.</Description>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <WarningsAsErrors>$(WarningsAsErrors);CS1591</WarningsAsErrors>
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Qyl.OpenTelemetry.AutoInstrumentation.Generated</InterceptorsNamespaces>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Qyl.OpenTelemetry.AutoInstrumentation.DiagnosticListeners" />
    <InternalsVisibleTo Include="Qyl.OpenTelemetry.AutoInstrumentation.Hosting" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Grpc.Core.Api" />
    <PackageReference Include="Qyl.OpenTelemetry.SemanticConventions" />
    <PackageReference Include="Qyl.OpenTelemetry.SemanticConventions.Incubating" />
  </ItemGroup>

  <ItemGroup>
    <None Include="build\Qyl.OpenTelemetry.AutoInstrumentation.targets"
          Pack="true"
          PackagePath="build\" />
    <None Include="buildTransitive\Qyl.OpenTelemetry.AutoInstrumentation.targets"
          Pack="true"
          PackagePath="buildTransitive\" />
    <None Include="$(ArtifactsPath)\bin\Qyl.OpenTelemetry.AutoInstrumentation.SourceGenerators\$(Configuration.ToLowerInvariant())\Qyl.OpenTelemetry.AutoInstrumentation.SourceGenerators.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs/"
          Visible="false" />
  </ItemGroup>

  <!-- Bake <Version> into a generated internal const so QylInstrumentation.Version (the OTel scope
       version stamped on every span/metric) is a pure compile-time value with ZERO reflection —
       reflection in product code is banned by verify-contract-invariants.py. Always runs (no
       Inputs/Outputs) so a CI `-p:Version` override is honoured; writes only on change to avoid
       needless recompiles. Emitted into obj/, never committed. -->
  <Target Name="GenerateQylVersionInfo" BeforeTargets="BeforeCompile;CoreCompile">
    <PropertyGroup>
      <_QylVersionInfoFile>$(IntermediateOutputPath)QylVersionInfo.g.cs</_QylVersionInfoFile>
    </PropertyGroup>
    <ItemGroup>
      <_QylVersionInfoLine Include="// &lt;auto-generated /&gt;" />
      <_QylVersionInfoLine Include="namespace Qyl.OpenTelemetry.AutoInstrumentation%3B" />
      <_QylVersionInfoLine Include="internal static class QylVersionInfo" />
      <_QylVersionInfoLine Include="{" />
      <_QylVersionInfoLine Include="    public const string Version = &quot;$(Version)&quot;%3B" />
      <_QylVersionInfoLine Include="}" />
    </ItemGroup>
    <WriteLinesToFile File="$(_QylVersionInfoFile)"
                      Lines="@(_QylVersionInfoLine)"
                      Overwrite="true"
                      WriteOnlyWhenDifferent="true" />
    <ItemGroup>
      <Compile Include="$(_QylVersionInfoFile)" />
      <FileWrites Include="$(_QylVersionInfoFile)" />
    </ItemGroup>
  </Target>

  <ItemGroup Condition="'$(PublishAot)' != 'true'">
    <!-- Source generator referenced as analyzer: emits the semconv FrozenSet at compile time so the
         runtime conformance check needs zero reflection (the substrate-era reflection path was JIT-only).
         It is build-time-only; NativeAOT publish must not try to publish the netstandard2.0 generator. -->
    <ProjectReference Include="..\Qyl.OpenTelemetry.AutoInstrumentation.SourceGenerators\Qyl.OpenTelemetry.AutoInstrumentation.SourceGenerators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"
                      GlobalPropertiesToRemove="PublishAot;PublishSingleFile;PublishTrimmed;RuntimeIdentifier;RuntimeIdentifiers;SelfContained" />
  </ItemGroup>

</Project>
