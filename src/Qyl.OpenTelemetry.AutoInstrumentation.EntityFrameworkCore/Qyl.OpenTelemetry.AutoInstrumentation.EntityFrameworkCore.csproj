<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Qyl.OpenTelemetry.AutoInstrumentation.EntityFrameworkCore</RootNamespace>
    <AssemblyName>Qyl.OpenTelemetry.AutoInstrumentation.EntityFrameworkCore</AssemblyName>
    <PackageId>Qyl.OpenTelemetry.AutoInstrumentation.EntityFrameworkCore</PackageId>
    <Description>Zero-code AOT-native EFCore DiagnosticSource instrumentation for qyl.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
  </ItemGroup>

  <ItemGroup>
    <None Include="buildTransitive\Qyl.OpenTelemetry.AutoInstrumentation.EntityFrameworkCore.targets"
          Pack="true"
          PackagePath="buildTransitive\" />
    <None Include="buildTransitive\Qyl.OpenTelemetry.AutoInstrumentation.EntityFrameworkCore.Bootstrap.g.cs"
          Pack="true"
          PackagePath="buildTransitive\" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Qyl.OpenTelemetry.AutoInstrumentation\Qyl.OpenTelemetry.AutoInstrumentation.csproj" />
    <ProjectReference Include="..\Qyl.OpenTelemetry.AutoInstrumentation.DiagnosticListeners\Qyl.OpenTelemetry.AutoInstrumentation.DiagnosticListeners.csproj" />
  </ItemGroup>

</Project>
