<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>Qyl.AutoInstrumentation.Cli</RootNamespace>

    <!-- Distributable as a dotnet global/local tool: `dotnet tool install qyl.AutoInstrumentation.Cli` -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>qyl</ToolCommandName>
    <PackageId>Qyl.AutoInstrumentation.Cli</PackageId>
    <Version>0.1.0</Version>
    <Description>Installs the qyl auto-instrumentation plugin into the OpenTelemetry .NET substrate store.</Description>

    <!-- Bundle the plugin + semconv DLLs into the tool so `qyl install` can deploy them. -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../qyl.AutoInstrumentation.Plugin/qyl.AutoInstrumentation.Plugin.csproj" />
  </ItemGroup>

</Project>
