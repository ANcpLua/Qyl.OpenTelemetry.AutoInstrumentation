{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qyl.dev/schemas/otel-dotnet-auto-60-contract-items.schema.json",
  "$comment": "<auto-generated/> Regenerate with tools/generate-contract-artifacts.py --write.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "generated_at",
    "source",
    "contract_items"
  ],
  "properties": {
    "schema_id": {
      "const": "otel-dotnet-auto-instrumentation-contract-items"
    },
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "source": {
      "type": "object"
    },
    "contract_items": {
      "type": "array",
      "minItems": 60,
      "maxItems": 60,
      "items": {
        "$ref": "#/$defs/contract_item"
      }
    }
  },
  "$defs": {
    "contract_item": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "kind",
        "key",
        "status",
        "index",
        "contract_item_id",
        "lane",
        "qyl_status",
        "call_site_visibility",
        "payload_access"
      ],
      "properties": {
        "kind": {
          "enum": [
            "signal_specific_instrumentation_promise",
            "global_environment_control",
            "instrumentation_option"
          ]
        },
        "signal": {
          "enum": [
            "traces",
            "metrics",
            "logs"
          ]
        },
        "lane": {
          "enum": [
            "environment_control",
            "framework_initialization",
            "instrumentation_option",
            "official_library_hook",
            "runtime_public_telemetry",
            "source_interceptor",
            "unsupported_nativeaot"
          ]
        },
        "qyl_status": {
          "enum": [
            "control_bound",
            "implemented",
            "option_bound",
            "research_required",
            "unsupported_nativeaot"
          ]
        },
        "call_site_visibility": {
          "enum": [
            "both",
            "library_internal",
            "not_applicable",
            "user_code"
          ]
        },
        "payload_access": {
          "enum": [
            "not_applicable",
            "reflection_required",
            "typed_public"
          ]
        },
        "index": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        },
        "contract_item_id": {
          "type": "string",
          "pattern": "^OTEL_DOTNET_AUTO_CONTRACT_[0-9]{3}$"
        },
        "key": {
          "type": "string"
        },
        "environment_toggle": {
          "type": "string"
        },
        "environment_variable": {
          "type": "string"
        },
        "instrumentation_id": {
          "type": "string"
        },
        "attribute_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
