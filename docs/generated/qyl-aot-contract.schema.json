{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qyl.dev/schemas/qyl-aot-contract.schema.json",
  "$comment": "<auto-generated/> Regenerate with tools/generate-contract-artifacts.py --write.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "generated_at",
    "source",
    "generated_from",
    "contract_items"
  ],
  "properties": {
    "schema_id": {
      "const": "qyl-aot-autoinstrumentation-resolved-contract"
    },
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "source": {
      "type": "object"
    },
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "upstream_contract",
        "qyl_ownership"
      ],
      "properties": {
        "upstream_contract": {
          "const": "docs/contracts/otel-dotnet-auto-60.upstream.yaml"
        },
        "qyl_ownership": {
          "const": "docs/contracts/qyl-aot-ownership.yaml"
        }
      }
    },
    "contract_items": {
      "type": "array",
      "minItems": 60,
      "maxItems": 60,
      "items": {
        "$ref": "#/$defs/contract_item"
      }
    }
  },
  "$defs": {
    "contract_item": {
      "oneOf": [
        {
          "$ref": "#/$defs/signal_item"
        },
        {
          "$ref": "#/$defs/control_item"
        },
        {
          "$ref": "#/$defs/option_item"
        }
      ]
    },
    "common_properties": {
      "kind": {
        "enum": [
          "signal_specific_instrumentation_promise",
          "global_environment_control",
          "instrumentation_option"
        ]
      },
      "key": {
        "type": "string"
      },
      "status": {
        "type": "string"
      },
      "index": {
        "type": "integer",
        "minimum": 1,
        "maximum": 60
      },
      "contract_item_id": {
        "type": "string",
        "pattern": "^OTEL_DOTNET_AUTO_CONTRACT_[0-9]{3}$"
      },
      "upstream_sources": {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "#/$defs/upstream_source"
        }
      },
      "lane": {
        "enum": [
          "environment_control",
          "framework_initialization",
          "instrumentation_option",
          "official_library_hook",
          "runtime_public_telemetry",
          "source_interceptor",
          "unsupported_nativeaot"
        ]
      },
      "qyl_status": {
        "enum": [
          "control_bound",
          "implemented",
          "option_bound",
          "research_required",
          "unsupported_nativeaot"
        ]
      },
      "call_site_visibility": {
        "enum": [
          "both",
          "library_internal",
          "not_applicable",
          "user_code"
        ]
      },
      "payload_access": {
        "enum": [
          "not_applicable",
          "reflection_required",
          "typed_public"
        ]
      },
      "evidence_level": {
        "enum": [
          "compile_binding_only",
          "none",
          "option_bound",
          "verified_managed",
          "verified_nativeaot"
        ]
      },
      "primary_owner": {
        "type": "string"
      },
      "evidence": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "conformance_signals": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/conformance_signal"
        }
      },
      "unsupported_reason": {
        "type": "string",
        "minLength": 1
      }
    },
    "signal_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "key",
        "status",
        "index",
        "contract_item_id",
        "upstream_sources",
        "lane",
        "qyl_status",
        "call_site_visibility",
        "payload_access",
        "evidence_level",
        "primary_owner",
        "evidence",
        "signal",
        "instrumentation_id",
        "environment_toggle",
        "libraries",
        "supported_versions",
        "instrumentation_types",
        "instrumentation_type_operator"
      ],
      "properties": {
        "call_site_visibility": {
          "enum": [
            "both",
            "library_internal",
            "not_applicable",
            "user_code"
          ]
        },
        "conformance_signals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/conformance_signal"
          }
        },
        "contract_item_id": {
          "type": "string",
          "pattern": "^OTEL_DOTNET_AUTO_CONTRACT_[0-9]{3}$"
        },
        "documentation": {
          "type": "object"
        },
        "environment_toggle": {
          "type": "string"
        },
        "environment_toggle_origin": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_level": {
          "enum": [
            "compile_binding_only",
            "none",
            "option_bound",
            "verified_managed",
            "verified_nativeaot"
          ]
        },
        "index": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        },
        "instrumentation_id": {
          "type": "string"
        },
        "instrumentation_type_operator": {
          "type": "string"
        },
        "instrumentation_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "key": {
          "type": "string"
        },
        "kind": {
          "const": "signal_specific_instrumentation_promise"
        },
        "lane": {
          "enum": [
            "environment_control",
            "framework_initialization",
            "instrumentation_option",
            "official_library_hook",
            "runtime_public_telemetry",
            "source_interceptor",
            "unsupported_nativeaot"
          ]
        },
        "libraries": {
          "type": "array"
        },
        "not_supported_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "payload_access": {
          "enum": [
            "not_applicable",
            "reflection_required",
            "typed_public"
          ]
        },
        "primary_owner": {
          "type": "string"
        },
        "qyl_status": {
          "enum": [
            "control_bound",
            "implemented",
            "option_bound",
            "research_required",
            "unsupported_nativeaot"
          ]
        },
        "signal": {
          "enum": [
            "traces",
            "metrics",
            "logs"
          ]
        },
        "status": {
          "type": "string"
        },
        "supported_versions": {
          "type": "string"
        },
        "unsupported_reason": {
          "type": "string",
          "minLength": 1
        },
        "upstream_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/upstream_source"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "lane": {
                "const": "runtime_public_telemetry"
              }
            }
          },
          "then": {
            "properties": {
              "payload_access": {
                "const": "typed_public"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "call_site_visibility": {
                "const": "library_internal"
              }
            }
          },
          "then": {
            "not": {
              "properties": {
                "lane": {
                  "const": "source_interceptor"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "payload_access": {
                "const": "reflection_required"
              }
            }
          },
          "then": {
            "not": {
              "properties": {
                "qyl_status": {
                  "const": "implemented"
                }
              }
            }
          }
        }
      ]
    },
    "control_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "key",
        "status",
        "index",
        "contract_item_id",
        "upstream_sources",
        "lane",
        "qyl_status",
        "call_site_visibility",
        "payload_access",
        "evidence_level",
        "primary_owner",
        "evidence",
        "environment_variable",
        "scope",
        "description"
      ],
      "properties": {
        "call_site_visibility": {
          "enum": [
            "both",
            "library_internal",
            "not_applicable",
            "user_code"
          ]
        },
        "conformance_signals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/conformance_signal"
          }
        },
        "contract_item_id": {
          "type": "string",
          "pattern": "^OTEL_DOTNET_AUTO_CONTRACT_[0-9]{3}$"
        },
        "default_value": {},
        "description": {
          "type": "string"
        },
        "environment_variable": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_level": {
          "enum": [
            "compile_binding_only",
            "none",
            "option_bound",
            "verified_managed",
            "verified_nativeaot"
          ]
        },
        "index": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        },
        "is_pattern": {
          "type": "boolean"
        },
        "key": {
          "type": "string"
        },
        "kind": {
          "const": "global_environment_control"
        },
        "lane": {
          "enum": [
            "environment_control",
            "framework_initialization",
            "instrumentation_option",
            "official_library_hook",
            "runtime_public_telemetry",
            "source_interceptor",
            "unsupported_nativeaot"
          ]
        },
        "overrides": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "payload_access": {
          "enum": [
            "not_applicable",
            "reflection_required",
            "typed_public"
          ]
        },
        "placeholder": {
          "type": "string"
        },
        "primary_owner": {
          "type": "string"
        },
        "qyl_status": {
          "enum": [
            "control_bound",
            "implemented",
            "option_bound",
            "research_required",
            "unsupported_nativeaot"
          ]
        },
        "scope": {
          "type": "string"
        },
        "signal": {
          "enum": [
            "traces",
            "metrics",
            "logs"
          ]
        },
        "status": {
          "type": "string"
        },
        "unsupported_reason": {
          "type": "string",
          "minLength": 1
        },
        "upstream_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/upstream_source"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "lane": {
                "const": "runtime_public_telemetry"
              }
            }
          },
          "then": {
            "properties": {
              "payload_access": {
                "const": "typed_public"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "call_site_visibility": {
                "const": "library_internal"
              }
            }
          },
          "then": {
            "not": {
              "properties": {
                "lane": {
                  "const": "source_interceptor"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "payload_access": {
                "const": "reflection_required"
              }
            }
          },
          "then": {
            "not": {
              "properties": {
                "qyl_status": {
                  "const": "implemented"
                }
              }
            }
          }
        }
      ]
    },
    "option_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "key",
        "status",
        "index",
        "contract_item_id",
        "upstream_sources",
        "lane",
        "qyl_status",
        "call_site_visibility",
        "payload_access",
        "evidence_level",
        "primary_owner",
        "evidence",
        "environment_variable",
        "target_signal",
        "target_instrumentation_id",
        "description",
        "attribute_names"
      ],
      "properties": {
        "attribute_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "call_site_visibility": {
          "enum": [
            "both",
            "library_internal",
            "not_applicable",
            "user_code"
          ]
        },
        "conformance_signals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/conformance_signal"
          }
        },
        "contract_item_id": {
          "type": "string",
          "pattern": "^OTEL_DOTNET_AUTO_CONTRACT_[0-9]{3}$"
        },
        "default_behavior": {
          "type": "string"
        },
        "default_value": {},
        "description": {
          "type": "string"
        },
        "environment_variable": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_level": {
          "enum": [
            "compile_binding_only",
            "none",
            "option_bound",
            "verified_managed",
            "verified_nativeaot"
          ]
        },
        "index": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        },
        "key": {
          "type": "string"
        },
        "kind": {
          "const": "instrumentation_option"
        },
        "lane": {
          "enum": [
            "environment_control",
            "framework_initialization",
            "instrumentation_option",
            "official_library_hook",
            "runtime_public_telemetry",
            "source_interceptor",
            "unsupported_nativeaot"
          ]
        },
        "not_supported_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "payload_access": {
          "enum": [
            "not_applicable",
            "reflection_required",
            "typed_public"
          ]
        },
        "primary_owner": {
          "type": "string"
        },
        "qyl_status": {
          "enum": [
            "control_bound",
            "implemented",
            "option_bound",
            "research_required",
            "unsupported_nativeaot"
          ]
        },
        "status": {
          "type": "string"
        },
        "target_instrumentation_id": {
          "type": "string"
        },
        "target_signal": {
          "enum": [
            "traces",
            "metrics",
            "logs"
          ]
        },
        "unsupported_reason": {
          "type": "string",
          "minLength": 1
        },
        "upstream_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/upstream_source"
          }
        },
        "value_format": {
          "type": "string"
        },
        "value_type": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "lane": {
                "const": "runtime_public_telemetry"
              }
            }
          },
          "then": {
            "properties": {
              "payload_access": {
                "const": "typed_public"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "call_site_visibility": {
                "const": "library_internal"
              }
            }
          },
          "then": {
            "not": {
              "properties": {
                "lane": {
                  "const": "source_interceptor"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "payload_access": {
                "const": "reflection_required"
              }
            }
          },
          "then": {
            "not": {
              "properties": {
                "qyl_status": {
                  "const": "implemented"
                }
              }
            }
          }
        }
      ]
    },
    "conformance_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name",
        "required_attributes",
        "recommended_attributes",
        "opt_in_attributes"
      ],
      "properties": {
        "kind": {
          "enum": [
            "log",
            "metric",
            "span"
          ]
        },
        "name": {
          "type": "string"
        },
        "required_attributes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_attributes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "opt_in_attributes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "upstream_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "pattern": "^https?://"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "contract_items": {
            "contains": {
              "properties": {
                "lane": {
                  "const": "runtime_public_telemetry"
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "contract_items": {
            "items": {
              "if": {
                "properties": {
                  "lane": {
                    "const": "runtime_public_telemetry"
                  }
                }
              },
              "then": {
                "properties": {
                  "payload_access": {
                    "const": "typed_public"
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
