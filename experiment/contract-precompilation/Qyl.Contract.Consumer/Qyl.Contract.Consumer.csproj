<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Net.Compilers.Toolset" Version="5.9.0-1.26324.7" PrivateAssets="all" />
    <ProjectReference Include="..\Qyl.Contract.Generator\Qyl.Contract.Generator.csproj"
                      OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <!-- The contract source-of-truth artifact (projected from the resolved YAML by Python) and the
         semantic-seed index. Both feed the PRE-COMPILATION phase. -->
    <AdditionalFiles Include="qyl-contract.tsv" />
    <AdditionalFiles Include="semantic-seeds.tsv" />
  </ItemGroup>

</Project>
