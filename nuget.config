<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- EXPERIMENT (precompilation in-place): the RegisterPreCompilationSourceOutput API is
         Roslyn main-only (5.9.0), shipped to NO stable feed. Only the dnceng dotnet-tools
         nightly feed carries Microsoft.Net.Compilers.Toolset / Microsoft.CodeAnalysis.* 5.9.0. -->
    <add key="roslyn-nightly" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-tools/nuget/v3/index.json" />
  </packageSources>
  <!-- Required under Central Package Management (NU1507) once more than one source exists.
       Scope the nightly feed to the exact Roslyn packages so the stable analyzers
       (Microsoft.CodeAnalysis.Analyzers, .PublicApiAnalyzers) keep resolving from nuget.org. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="roslyn-nightly">
      <package pattern="Microsoft.CodeAnalysis.CSharp" />
      <package pattern="Microsoft.CodeAnalysis.Common" />
      <package pattern="Microsoft.CodeAnalysis.Analyzers" />
      <package pattern="Microsoft.Net.Compilers.Toolset" />
    </packageSource>
  </packageSourceMapping>
</configuration>
